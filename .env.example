# ── Database (VPS: these three build the DATABASE_URL inside docker-compose) ──
POSTGRES_USER=prepaired
POSTGRES_PASSWORD=changeme
POSTGRES_DB=prepaired_questions
# Local dev only — on VPS this is auto-constructed from the three vars above
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/prepaired

# ── Supabase (for JWT verification + existing tables during transition) ────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://www.prepaired.site,http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
FREE_QUESTION_LIMIT=10

# ── GitHub (Legacy Score Push) ────────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=your_github_repo_here
